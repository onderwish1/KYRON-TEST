                  </li>
                ))}
              </ul>
            </motion.div>
          ))}
        </div>

        {/* Status indicator */}
        <motion.div 
          initial={{ opacity: 0 }}
          whileInView={{ opacity: 1 }}
          viewport={{ once: true }}
          className="flex items-center gap-2 mb-8"
        >
          <span className="w-2 h-2 bg-green-400 rounded-full animate-pulse" />
          <span className="text-sm text-white/80">All systems normal</span>
        </motion.div>

        {/* Bottom bar */}
