import { motion } from 'framer-motion';
import { Monitor, Moon, Sun } from 'lucide-react';
import { useState } from 'react';

export function Footer() {
  const [theme, setTheme] = useState<'light' | 'dark' | 'system'>('system');

  const footerLinks = {
    Platform: ['Diagnose', 'Fix', 'Prevent', 'Get Answers'],
    Company: ['Pricing', 'Careers', 'Resources'],
    Legal: ['Terms', 'Privacy'],
    Connect: ['X (Twitter)', 'LinkedIn', 'GitHub'],
  };

  return (
    <footer className="relative bg-gradient-to-b from-[#001a4d] to-[#000428] pt-16 pb-8 overflow-hidden">
      {/* Grid overlay */}
      <div 
        className="absolute inset-0 opacity-5"
        style={{
          backgroundImage: `
            linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px)
          `,
          backgroundSize: '100px 100px'
        }}
      />

      <div className="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        {/* Links grid */}
        <div className="grid grid-cols-2 md:grid-cols-4 gap-8 mb-16">
          {Object.entries(footerLinks).map(([category, links], categoryIndex) => (
            <motion.div
              key={category}
              initial={{ opacity: 0, y: 20 }}
              whileInView={{ opacity: 1, y: 0 }}
              viewport={{ once: true }}
              transition={{ delay: categoryIndex * 0.1 }}
            >
              <h3 className="text-sm font-medium text-slate-400 mb-4">{category}</h3>
              <ul className="space-y-3">
                {links.map((link) => (
                  <li key={link}>
                    <a 
                      href="#" 
                      className="text-sm text-white/80 hover:text-white transition-colors"
